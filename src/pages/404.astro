---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="页面不存在" description="找不到该页面">
  <div class="container" style="padding-top: 5rem; padding-bottom: 5rem; text-align: center">
    <p style="font-size: 5rem; line-height: 1; margin-bottom: 1rem">404</p>
    <h1 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 0.75rem">页面不存在</h1>
    <p style="color: var(--color-text-muted); margin-bottom: 2rem">你访问的页面已移动或不存在。</p>
    <a href="/" class="btn btn-primary">回到首页</a>
  </div>
</BaseLayout>
