---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---
<BaseLayout
  title="周度观察"
  description="周度观察 — 每周更新行业观察、认知思考与随笔干货"
>
  <div class="container">
    <section class="hero">
      <span class="hero-label">Weekly Newsletter</span>
      <h1>周度观察</h1>
      <p class="hero-bio">
        每周更新行业观察、认知思考与随笔干货——
        把值得记录的信号从噪音中筛出来，留给自己，也分享给你。
      </p>
      <div class="hero-actions">
        <a href="/blog" class="btn btn-primary">往期回顾</a>
        <a href="/about" class="btn btn-outline">关于我</a>
      </div>
    </section>

    <section>
      <div class="section-header">
        <h2>最新一期</h2>
        <a href="/blog">全部期次 →</a>
      </div>

      <div class="post-list">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="post-card">
            <span class="post-date">
              <FormattedDate date={post.data.pubDate} />
            </span>
            <div>
              <div class="post-card-title">{post.data.title}</div>
              <div class="post-card-desc">{post.data.description}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
